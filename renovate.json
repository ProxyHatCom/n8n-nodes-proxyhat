{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits"],
  "labels": ["dependencies"],
  "schedule": ["before 6am on monday"],
  "packageRules": [
    {
      "description": "Auto-merge dev-dependency and upstream bumps once CI is green.",
      "matchDepTypes": ["devDependencies", "dependencies"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Track the n8n-workflow peer range but never auto-widen it silently.",
      "matchPackageNames": ["n8n-workflow"],
      "matchDepTypes": ["peerDependencies"],
      "automerge": false
    }
  ]
}
